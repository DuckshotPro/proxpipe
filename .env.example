# ============================================================
# proxpipe — All Free Tier Tokens & Endpoints In One Place
# ============================================================

# --- Antigravity Proxy ---
ANTIGRAVITY_URL=http://localhost:8080
ANTHROPIC_API_KEY=fake-key-proxy-handles-auth
ANTHROPIC_BASE_URL=http://localhost:8080

# --- Gemini OAuth (free via Google subscription) ---
# Get this from: gcloud auth print-access-token
# Or the proxy handles it automatically if Google account is connected
GEMINI_OAUTH_TOKEN=
GEMINI_PROJECT_ID=

# --- Perplexity (Pro subscription session token) ---
# sleepy-perp extracts this via headless browser
# Point at your running sleepy-perp instance
SLEEPY_PERP_URL=http://localhost:3001
PERPLEXITY_SESSION_TOKEN=

# --- GitHub (free tier) ---
# From: gh auth token
GITHUB_TOKEN=
GITHUB_OWNER=DuckshotPro
# When moved to org:
# GITHUB_OWNER=Duckshot-Productions

# --- GitHub Models API (free inference) ---
# Same GITHUB_TOKEN above — no extra setup
GITHUB_MODELS_URL=https://models.inference.ai.azure.com

# --- AutonomiX ---
AUTONOMIX_ENDPOINT=ws://localhost:3000

# --- n8n ---
N8N_URL=http://localhost:5678
N8N_WEBHOOK_SECRET=changeme

# --- proxpipe webhook receiver ---
WEBHOOK_PORT=4000
WEBHOOK_SECRET=changeme

# --- GitHub Projects ---
# Project node ID from GraphQL: gh api graphql -f query='{ viewer { projectsV2(first:5) { nodes { id title } } } }'
GITHUB_PROJECT_ID=
# Status field IDs — get from project schema query
STATUS_FIELD_ID=
STATUS_IN_PROGRESS_VALUE=
STATUS_DONE_VALUE=
